      <caption>Pomodoro timer applet on the COSMIC panel</caption>
    </screenshot>
  </screenshots>

  <provides>
    <binary>cosmic-ext-applet-pomodoro</binary>
  </provides>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>

  <categories>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>COSMIC</keyword>
    <keyword>pomodoro</keyword>
