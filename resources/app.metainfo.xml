<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.bgub.CosmicExtAppletPomodoro</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <project_group>COSMIC</project_group>
  <name>Pomodoro Timer</name>
  <summary>A pomodoro timer applet for the COSMIC desktop</summary>

  <developer id="com.github.bgub">
    <name>bgub</name>
  </developer>

  <url type="homepage">https://github.com/cosmic-utils/cosmic-ext-applet-pomodoro</url>
  <url type="bugtracker">https://github.com/cosmic-utils/cosmic-ext-applet-pomodoro/issues</url>

  <description>
